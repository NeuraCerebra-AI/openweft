{
  "name": "openweft",
  "version": "0.1.0",
  "description": "AI coding work orchestrator for Codex CLI and Claude Code",
  "homepage": "https://github.com/NeuraCerebra-AI/openweft#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/NeuraCerebra-AI/openweft.git"
  },
  "bugs": {
    "url": "https://github.com/NeuraCerebra-AI/openweft/issues"
  },
  "license": "MIT",
  "type": "module",
  "packageManager": "npm@11.6.0",
  "bin": {
    "openweft": "dist/bin/openweft.js"
  },
  "files": [
    "dist"
  ],
  "keywords": [
    "ai",
    "agent",
    "cli",
    "codex",
    "claude",
    "worktree",
    "orchestration"
  ],
  "engines": {
    "node": ">=24.0.0"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "prepare": "npm run build",
    "prepublishOnly": "npm run typecheck && npm test",
    "release:smoke:packaged-cli": "node scripts/packaged-cli-smoke.mjs",
    "release:check": "npm run typecheck && npm test && npm run build && npm run release:smoke:packaged-cli && npm publish --dry-run",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "openweft": "tsx src/bin/openweft.ts",
    "smoke:live:codex": "node scripts/live-smoke.mjs codex",
    "smoke:live:codex:resume": "node scripts/live-smoke.mjs codex resume",
    "smoke:live:claude": "node scripts/live-smoke.mjs claude",
    "demo:record": "bash scripts/record-demo.sh"
  },
  "dependencies": {
    "@inkjs/ui": "^2.0.0",
    "cli-spinners": "^3.4.0",
    "commander": "14.0.3",
    "cosmiconfig": "9.0.1",
    "execa": "9.6.1",
    "figures": "^6.1.0",
    "fullscreen-ink": "^0.1.0",
    "ink": "^5.2.1",
    "is-unicode-supported": "^2.1.0",
    "json5": "2.2.3",
    "jsonrepair": "3.13.3",
    "marked": "^15.0.12",
    "marked-terminal": "^7.3.0",
    "mdast-util-to-string": "4.0.0",
    "node-notifier": "10.0.1",
    "p-queue": "9.1.0",
    "pino": "10.3.1",
    "pino-pretty": "13.1.3",
    "react": "^18.3.1",
    "remark-parse": "11.0.0",
    "simple-git": "3.33.0",
    "supports-color": "^10.2.2",
    "unified": "11.0.5",
    "unist-util-visit": "5.1.0",
    "write-file-atomic": "7.0.1",
    "xstate": "5.28.0",
    "zod": "4.1.0",
    "zustand": "^5.0.11"
  },
  "devDependencies": {
    "@types/marked-terminal": "^6.1.1",
    "@types/node": "25.5.0",
    "@types/node-notifier": "8.0.5",
    "@types/react": "^18.3.2",
    "@types/write-file-atomic": "4.0.3",
    "ink-testing-library": "^4.0.0",
    "tsx": "4.21.0",
    "typescript": "5.9.3",
    "vitest": "4.1.0"
  }
}
